{
  "name": "jonmagic-scripts",
  "displayName": "Jonmagic Scripts",
  "description": "Utilities for my Brain repo, including weekly navigation and wikilink preview",
  "version": "0.0.0",
  "publisher": "jonmagic",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonmagic/scripts",
    "directory": "packages/vscode"
  },
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:jonmagic.openDailyProject",
    "onCommand:jonmagic.openWeeklyNote",
    "onCommand:jonmagic.openProjectNote",
    "onCommand:jonmagic.openMeetingNote",
    "onCommand:jonmagic.openBookmark",
    "onCommand:jonmagic.openRecentBrainFile",
    "onCommand:jonmagic.copyPathWikilink",
    "onCommand:jonmagic.copyUidWikilink",
    "onCommand:jonmagic.appendWeeklyTodo",
    "onCommand:jonmagic.captureWeeklyNote",
    "onCommand:jonmagic.showWeeklyFocus",
    "onCommand:jonmagic.addReferenceToProject",
    "onCommand:jonmagic.rebuildIndex",
    "onView:brainWeekView",
    "onView:brainContextWorkbenchView"
  ],
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jonmagic.createDailyProjectNote",
        "title": "Brain: Create Daily Project Note"
      },
      {
        "command": "jonmagic.addFrontmatter",
        "title": "Brain: Add Frontmatter to Current File"
      },
      {
        "command": "jonmagic.createBookmark",
        "title": "Brain: Create Bookmark"
      },
      {
        "command": "jonmagic.openRecentBrainFile",
        "title": "Brain: Open Recent Brain File"
      },
      {
        "command": "jonmagic.openDailyProject",
        "title": "Brain: Open Daily Project"
      },
      {
        "command": "jonmagic.openWeeklyNote",
        "title": "Brain: Open Weekly Note"
      },
      {
        "command": "jonmagic.openProjectNote",
        "title": "Brain: Open Project Note"
      },
      {
        "command": "jonmagic.openMeetingNote",
        "title": "Brain: Open Meeting Note"
      },
      {
        "command": "jonmagic.openBookmark",
        "title": "Brain: Open Bookmark"
      },
      {
        "command": "jonmagic.copyPathWikilink",
        "title": "Brain: Copy Path Wikilink"
      },
      {
        "command": "jonmagic.copyUidWikilink",
        "title": "Brain: Copy UID Wikilink"
      },
      {
        "command": "jonmagic.appendWeeklyTodo",
        "title": "Brain: Append Weekly Note TODO"
      },
      {
        "command": "jonmagic.captureWeeklyNote",
        "title": "Brain: Capture to Weekly Note",
        "icon": "$(add)"
      },
      {
        "command": "jonmagic.showWeeklyFocus",
        "title": "Brain: Show Weekly Focus",
        "icon": "$(target)"
      },
      {
        "command": "jonmagic.addReferenceToProject",
        "title": "Brain: Add Reference to Project"
      },
      {
        "command": "jonmagic.rebuildIndex",
        "title": "Brain: Rebuild Index",
        "icon": "$(sync)"
      },
      {
        "command": "jonmagic.previousWeek",
        "title": "Brain: Previous Week",
        "icon": "$(arrow-left)"
      },
      {
        "command": "jonmagic.nextWeek",
        "title": "Brain: Next Week",
        "icon": "$(arrow-right)"
      },
      {
        "command": "jonmagic.goToCurrentWeek",
        "title": "Brain: Go to Current Week",
        "icon": "$(home)"
      },
      {
        "command": "jonmagic.refresh",
        "title": "Brain: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "jonmagic.refreshContextWorkbench",
        "title": "Brain: Refresh Context Workbench",
        "icon": "$(refresh)"
      },
      {
        "command": "jonmagic.openPreview",
        "title": "Open Preview"
      },
      {
        "command": "jonmagic.openToSide",
        "title": "Open to the Side"
      },
      {
        "command": "jonmagic.openWith",
        "title": "Open With..."
      },
      {
        "command": "jonmagic.revealInFinder",
        "title": "Reveal in Finder"
      },
      {
        "command": "jonmagic.addFileToChat",
        "title": "Add File to Chat"
      },
      {
        "command": "jonmagic.copyFile",
        "title": "Copy"
      },
      {
        "command": "jonmagic.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "jonmagic.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "jonmagic.renameFile",
        "title": "Rename..."
      },
      {
        "command": "jonmagic.deleteFile",
        "title": "Delete"
      }
    ],
    "configuration": {
      "title": "Jonmagic Scripts",
      "properties": {
        "jonmagic.brainPath": {
          "type": "string",
          "default": "~/Brain",
          "description": "Path to the Brain repository folder"
        }
      }
    },
    "markdown.markdownItPlugins": true,
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brain-sidebar",
          "title": "Brain",
          "icon": "$(book)"
        }
      ],
      "secondarySidebar": [
        {
          "id": "brain-context-workbench",
          "title": "Brain Context",
          "icon": "$(references)"
        }
      ]
    },
    "views": {
      "brain-sidebar": [
        {
          "id": "brainWeekView",
          "name": "This Week",
          "contextualTitle": "Brain"
        }
      ],
      "brain-context-workbench": [
        {
          "id": "brainContextWorkbenchView",
          "name": "Context",
          "contextualTitle": "Brain Context"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "jonmagic.openPreview",
          "when": "false"
        },
        {
          "command": "jonmagic.openToSide",
          "when": "false"
        },
        {
          "command": "jonmagic.openWith",
          "when": "false"
        },
        {
          "command": "jonmagic.revealInFinder",
          "when": "false"
        },
        {
          "command": "jonmagic.addFileToChat",
          "when": "false"
        },
        {
          "command": "jonmagic.copyFile",
          "when": "false"
        },
        {
          "command": "jonmagic.copyPath",
          "when": "false"
        },
        {
          "command": "jonmagic.copyRelativePath",
          "when": "false"
        },
        {
          "command": "jonmagic.renameFile",
          "when": "false"
        },
        {
          "command": "jonmagic.deleteFile",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "jonmagic.captureWeeklyNote",
          "when": "view == brainWeekView",
          "group": "navigation@0"
        },
        {
          "command": "jonmagic.showWeeklyFocus",
          "when": "view == brainWeekView",
          "group": "navigation@0.5"
        },
        {
          "command": "jonmagic.previousWeek",
          "when": "view == brainWeekView && jonmagic.hasPreviousWeek",
          "group": "navigation@1"
        },
        {
          "command": "jonmagic.nextWeek",
          "when": "view == brainWeekView && jonmagic.hasNextWeek",
          "group": "navigation@2"
        },
        {
          "command": "jonmagic.goToCurrentWeek",
          "when": "view == brainWeekView",
          "group": "navigation@3"
        },
        {
          "command": "jonmagic.refresh",
          "when": "view == brainWeekView",
          "group": "navigation@4"
        },
        {
          "command": "jonmagic.rebuildIndex",
          "when": "view == brainWeekView",
          "group": "navigation@5"
        },
        {
          "command": "jonmagic.refreshContextWorkbench",
          "when": "view == brainContextWorkbenchView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "jonmagic.openToSide",
          "when": "view == brainWeekView && viewItem == brainFile",
          "group": "1_open@1"
        },
        {
          "command": "jonmagic.addFileToChat",
          "when": "view == brainWeekView && viewItem == brainFile",
          "group": "4_chat@1"
        },
        {
          "command": "jonmagic.copyPathWikilink",
          "when": "view == brainWeekView && viewItem == brainFile",
          "group": "5_cutcopypaste@1"
        },
        {
          "command": "jonmagic.copyUidWikilink",
          "when": "view == brainWeekView && viewItem == brainFile",
          "group": "5_cutcopypaste@2"
        },
        {
          "command": "jonmagic.addReferenceToProject",
          "when": "view == brainWeekView && viewItem == brainFile",
          "group": "6_brain@1"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "package": "bunx @vscode/vsce package --no-dependencies --skip-license",
    "typecheck": "bun tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jonmagic/scripts-core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "typescript": "^5.8.2"
  }
}
