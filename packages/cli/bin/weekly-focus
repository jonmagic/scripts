#!/usr/bin/env bun
/**
 * weekly-focus: Print a low-noise focus view from the current weekly note.
 *
 * Usage:
 *   weekly-focus [--brain-root PATH]
 */

import { parseArgs } from "node:util"
import { formatWeeklyFocus, runWeeklyFocus } from "../src/weekly-note-commitments.js"

const { values } = parseArgs({
  options: {
    "brain-root": { type: "string" },
    "weekly-note-path": { type: "string" },
    limit: { type: "string" },
    help: { type: "boolean", short: "h" },
  },
})

if (values.help) {
  console.log(`
Usage: weekly-focus [options]

Options:
  --brain-root PATH        Override Brain root directory
  --weekly-note-path PATH  Override the weekly note path
  --limit N                Max TODO items to read (default: 5)
  -h, --help               Show this help message
`)
  process.exit(0)
}

const limit =
  values.limit === undefined ? undefined : Number.parseInt(values.limit, 10)

if (
  values.limit !== undefined &&
  (!Number.isInteger(limit) || limit < 0 || String(limit) !== values.limit)
) {
  console.error("--limit must be a non-negative integer")
  process.exit(1)
}

const focus = await runWeeklyFocus({
  brainRoot: values["brain-root"],
  todoLimit: limit,
  weeklyNotePath: values["weekly-note-path"],
})

console.log(formatWeeklyFocus(focus))
