#!/usr/bin/env bash
#
# Install the CLI tools by symlinking them into ~/.local/bin.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
CLI_BIN_DIR="$ROOT_DIR/packages/cli/bin"
INSTALL_DIR="$HOME/.local/bin"

mkdir -p "$INSTALL_DIR"

echo "==> Installing CLI tools into $INSTALL_DIR..."

for tool in "$CLI_BIN_DIR"/*; do
  name="$(basename "$tool")"
  target="$INSTALL_DIR/$name"

  if [[ -e "$target" && ! -L "$target" ]]; then
    echo "    Skipping $name (non-symlink file already exists)"
    continue
  fi

  ln -sf "$tool" "$target"
  echo "    Linked $name"
done

echo ""
echo "==> Done!"

if ! echo "$PATH" | tr ':' '\n' | grep -qx "$INSTALL_DIR"; then
  echo ""
  echo "Note: $INSTALL_DIR is not in your PATH."
  echo "Add this to your shell config:"
  echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
fi
