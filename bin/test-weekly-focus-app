#!/usr/bin/env bash
#
# Exercise the native Weekly Focus app against a temporary Brain.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
TMPDIR="$(mktemp -d)"
LAUNCH_FILE="/tmp/weekly-focus-app-launch-self-test.txt"
TEST_RUN_ID="weekly-focus-test-$$"
TODO_ONE="One $TEST_RUN_ID"
TODO_TWO="Two $TEST_RUN_ID"
APP_EXECUTABLE="$ROOT_DIR/packages/focus-app/.build/Weekly Focus.app/Contents/MacOS/Weekly Focus"
APP_PID=""

stop_existing_app() {
  while read -r pid; do
    if [[ -n "$pid" ]]; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done < <(ps -axo pid=,args= | grep -F 'Weekly Focus.app/Contents/MacOS/Weekly Focus' | grep -v grep | awk '{print $1}')
}

cleanup() {
  if [[ -n "${APP_PID:-}" ]]; then
    kill "$APP_PID" >/dev/null 2>&1 || true
    wait "$APP_PID" 2>/dev/null || true
  fi
  for workspace in $(cmux workspace list 2>/dev/null | awk -v id="$TEST_RUN_ID" '/Self-test launch/ || index($0, id) {print $1}'); do
    cmux workspace close "$workspace" >/dev/null 2>&1 || true
  done
  rm -rf "$TMPDIR"
  rm -f "$LAUNCH_FILE"
}
trap cleanup EXIT

mkdir -p "$TMPDIR/Weekly Notes"
WEEKLY_NOTE="$TMPDIR/Weekly Notes/Week of 2026-07-05.md"

cat >"$WEEKLY_NOTE" <<MARKDOWN
# Week

## TODO
- [ ] $TODO_ONE
- [ ] $TODO_TWO

## Captured
MARKDOWN

rm -f "$LAUNCH_FILE"

BRAIN_ROOT="$TMPDIR" swift run \
  --package-path "$ROOT_DIR/packages/focus-app" \
  weekly-focus-app \
  --self-test \
  --self-test-launch

grep -q 'Self-test todo' "$WEEKLY_NOTE"
grep -q -- "- \\[x\\] $TODO_ONE" "$WEEKLY_NOTE"

for _ in {1..20}; do
  if [[ -f "$LAUNCH_FILE" ]]; then
    break
  fi
  sleep 0.25
done

grep -q 'weekly-focus-launch-ok' "$LAUNCH_FILE"

cat >"$WEEKLY_NOTE" <<MARKDOWN
# Week

## TODO
- [ ] $TODO_ONE
- [ ] $TODO_TWO

## Captured
MARKDOWN

UI_TODO="UI entered TODO $$"

stop_existing_app

BRAIN_ROOT="$TMPDIR" "$APP_EXECUTABLE" &
APP_PID=$!

for _ in {1..40}; do
  if ps -p "$APP_PID" >/dev/null 2>&1 && osascript -e "tell application \"System Events\" to exists (first process whose unix id is $APP_PID)" 2>/dev/null | grep -q true; then
    break
  fi
  sleep 0.25
done

perl -0pi -e "s/- \\[ \\] \\Q$TODO_ONE\\E/- [x] $TODO_ONE/" "$WEEKLY_NOTE"
grep -q -- "- \\[x\\] $TODO_ONE" "$WEEKLY_NOTE"

FIRST_TODO_TITLE=""
for _ in {1..40}; do
  FIRST_TODO_TITLE="$(osascript <<APPLESCRIPT 2>/dev/null || true
set appPid to $APP_PID
tell application "System Events"
  set appProcess to first process whose unix id is appPid
  tell appProcess
    return name of button 1 of window "Weekly Focus"
  end tell
end tell
APPLESCRIPT
)"
  if [[ "$FIRST_TODO_TITLE" == *"$TODO_TWO"* ]]; then
    break
  fi
  sleep 0.25
done

if [[ "$FIRST_TODO_TITLE" != *"$TODO_TWO"* ]]; then
  echo "Weekly Focus did not refresh after external weekly note edit; saw: $FIRST_TODO_TITLE" >&2
  exit 1
fi

osascript <<APPLESCRIPT
set appPid to $APP_PID
tell application "System Events"
  set appProcess to first process whose unix id is appPid
  tell appProcess
    set frontmost to true
    delay 0.5
    click text field 1 of window "Weekly Focus"
    keystroke "$UI_TODO"
    key code 36
  end tell
end tell
APPLESCRIPT

for _ in {1..20}; do
  if grep -q "$UI_TODO" "$WEEKLY_NOTE"; then
    break
  fi
  sleep 0.25
done

grep -q "$UI_TODO" "$WEEKLY_NOTE"

osascript <<APPLESCRIPT
set appPid to $APP_PID
tell application "System Events"
  set appProcess to first process whose unix id is appPid
  tell appProcess
    set frontmost to true
    delay 0.5
    key code 12 using {command down}
  end tell
end tell
APPLESCRIPT

for _ in {1..20}; do
  if ! ps -p "$APP_PID" >/dev/null 2>&1; then
    break
  fi
  sleep 0.25
done

if ps -p "$APP_PID" >/dev/null 2>&1; then
  echo "Weekly Focus did not quit on Cmd-Q" >&2
  exit 1
fi

wait "$APP_PID" 2>/dev/null || true
APP_PID=""

echo "weekly-focus app self-test passed"
